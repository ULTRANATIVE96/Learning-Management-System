# myTutor Frontend Environment Configuration
# Copy this file to '.env' and modify the values as needed.

# The HTTP/HTTPS API URL of the Spring Boot backend service
# Example for Local: http://localhost:8080/api
# Example for Production: https://mytutor-backend.onrender.com/api
VITE_API_URL=http://localhost:8080/api

# The WebSocket host and port (without protocol) of the Spring Boot backend service
# Example for Local: localhost:8080
# Example for Production: mytutor-backend.onrender.com
VITE_API_WS_URL=localhost:8080
