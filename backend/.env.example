# myTutor Java Spring Boot Backend Environment Configuration
# Define these environment variables in your Render Web Service or local environment.

# The port on which the Spring Boot application will run
# Default: 8080 (Render injects PORT automatically)
PORT=8080

# Database Configuration
# --------------------------------------------------
# Default configurations below use local file-based H2 database.
# Switch these values to connect to a PostgreSQL database (e.g. Render PostgreSQL) in production.

# JDBC connection URL
# Local H2: jdbc:h2:file:./data/mytutordb;DB_CLOSE_DELAY=-1;AUTO_SERVER=TRUE
# Production Postgres: jdbc:postgresql://<host>:<port>/<database>
SPRING_DATASOURCE_URL=jdbc:h2:file:./data/mytutordb;DB_CLOSE_DELAY=-1;AUTO_SERVER=TRUE

# Database username
# Local H2: sa
# Production Postgres: <your_db_username>
SPRING_DATASOURCE_USERNAME=sa

# Database password
# Local H2: (empty)
# Production Postgres: <your_db_password>
SPRING_DATASOURCE_PASSWORD=

# JDBC Driver Class Name
# Local H2: org.h2.Driver
# Production Postgres: org.postgresql.Driver
SPRING_DATASOURCE_DRIVER=org.h2.Driver
